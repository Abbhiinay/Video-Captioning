# Fireworks AI API
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Model names (fill in once revealed on launch day)
FIREWORKS_VISION_MODEL=
FIREWORKS_LLM_MODEL=

# AMD Developer Cloud (if using GPU instance directly)
AMD_DEV_CLOUD_ENDPOINT=
AMD_DEV_CLOUD_API_KEY=

# Optional: Whisper / audio transcription
ENABLE_AUDIO_TRANSCRIPT=false

# Paths
CLIPS_DIR=data/clips
OUTPUT_DIR=data/outputs